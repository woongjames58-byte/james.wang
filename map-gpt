<!DOCTYPE html>
<html lang="zh-CN">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>
Disney Typhoon Tree Recovery Dashboard
</title>


<!-- 高德地图安全配置 -->

<script>

window._AMapSecurityConfig = {

securityJsCode:
'87f30e10906fa7218d780a9a179c69f89'

}

</script>


<!-- 高德地图 -->

<script src="https://webapi.amap.com/maps?v=2.0&key=ecc7bff9b574a80ad34e4d51bab69aca"></script>


<!-- Supabase -->

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>


<!-- CSS -->

<link rel="stylesheet" href="css/style.css">


</head>


<body>


<!-- 顶部标题 -->

<div class="header">

<h1>
Shanghai Disney Resort
</h1>

<h2>
Typhoon Tree Recovery Dashboard
</h2>

</div>



<!-- Dashboard切换 -->

<div class="dashboard-menu">


<button class="dashboard-btn active"
onclick="switchDashboard(1)">

🚗 出入口及周边道路

</button>



<button class="dashboard-btn"
onclick="switchDashboard(2)">

🛣 乐园主要道路

</button>



<button class="dashboard-btn"
onclick="switchDashboard(3)">

📍 重点设施风险

</button>



<button class="dashboard-btn"
onclick="switchDashboard(4)">

🔥 风险热力图

</button>


</div>





<!-- KPI -->

<div class="kpi-container">


<div class="kpi-card">

<div>
Total Damaged Trees
</div>

<strong id="totalTrees">
0
</strong>

</div>



<div class="kpi-card">

<div>
Max Recover Time
</div>

<strong id="recoverTime">
0 h
</strong>

</div>



<div class="kpi-card">

<div>
Open Work Orders
</div>

<strong id="openOrders">
0
</strong>

</div>


</div>





<!-- 地图 -->

<div id="map-container"></div>





<!-- 上报按钮 -->


<div class="action-bar">


<button onclick="startReport()">

📍 新增倒树事件

</button>



<button onclick="reloadData()">

🔄 刷新数据

</button>


</div>





<!-- Dashboard信息窗口 -->

<div id="dashboard-panel">


</div>



<!-- 上报窗口 -->


<div class="modal" id="reportModal">


<div class="modal-box">


<h3>
现场倒树上报
</h3>


<label>
上报人
</label>


<input id="reporterInput">



<label>
区域
</label>


<select id="zoneInput">

<option>
米奇大街
</option>

<option>
梦幻世界
</option>

<option>
探险岛
</option>

<option>
宝藏湾
</option>

<option>
疯狂动物城
</option>


</select>


<label>
树木数量
</label>


<input id="treeInput"
type="number"
value="1">



<label>
照片
</label>


<input id="photoInput"
type="file"
accept="image/*">



<button onclick="submitReport()">

提交

</button>


<button onclick="closeModal()">

取消

</button>



</div>


</div>
